PROJECT_NAME = "Linux Virtual Block Device Module"
PROJECT_NUMBER = 1.0
INPUT_ENCODING = UTF-8
OUTPUT_LANGUAGE = Russian
PROJECT_BRIEF = "Virtual RAM block device kernel module"
USE_MDFILE_AS_MAINPAGE = README.md

INPUT = src README.md
RECURSIVE = NO
FILE_PATTERNS = *.c *.h
SOURCE_BROWSER = YES
SHOW_FILES = YES

OUTPUT_DIRECTORY = docs
GENERATE_HTML = YES
GENERATE_LATEX = NO
HAVE_DOT = YES

GENERATE_TREEVIEW = YES
DISABLE_INDEX = NO
FULL_SIDEBAR = NO
HTML_EXTRA_STYLESHEET = assets/doxygen-awesome.css
HTML_HEADER = assets/header.html
HTML_FOOTER = assets/footer.html
HTML_EXTRA_FILES = assets/doxygen-awesome-darkmode-toggle.js \
                   assets/doxygen-awesome-fragment-copy-button.js \
                   assets/doxygen-awesome-interactive-toc.js \
                   assets/doxygen-awesome-paragraph-link.js
EXCLUDE = assets/custom.css.bak

INLINE_SOURCES = NO
OPTIMIZE_OUTPUT_FOR_C = YES
EXTRACT_ALL = YES
EXTRACT_STATIC = YES
QUIET = YES
WARN_AS_ERROR = NO
WARN_IF_UNDOCUMENTED = YES
HIDE_UNDOC_MEMBERS = NO
ENABLED_SECTIONS =
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = YES

PREDEFINED = __init= \
             __exit= \
             MODULE_LICENSE(x)= \
             MODULE_AUTHOR(x)= \
             MODULE_DESCRIPTION(x)= \
             MODULE_VERSION(x)= \
             module_init(x)= \
             module_exit(x)=
